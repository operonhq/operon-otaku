{
  "name": "@elizaos/plugin-polymarket-trading",
  "version": "1.6.2-alpha.14",
  "description": "Polymarket prediction markets trading plugin for ElizaOS with CDP wallet support",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun run build.ts --watch",
    "typecheck": "tsc --project tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "@coinbase/cdp-sdk": "1.38.6",
    "@polymarket/clob-client": "^5.1.3",
    "@polymarket/sdk": "^6.0.1",
    "viem": "2.41.2"
  },
  "peerDependencies": {
    "@elizaos/core": "1.6.4"
  },
  "devDependencies": {
    "@types/bun": "^1.2.21",
    "@types/node": "^22.15.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "publishConfig": {
    "access": "public",
    "workspaces": {
      "preserveIfPresent": true
    }
  },
  "keywords": [
    "polymarket",
    "prediction-markets",
    "trading",
    "defi",
    "cdp",
    "eliza",
    "elizaos",
    "plugin"
  ],
  "author": "ElizaOS",
  "license": "MIT"
}

